{
  "name": "ng-primitives-docs",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "apps/ng-primitives-docs/src",
  "tags": [],
  "implicitDependencies": ["ng-primitives", "ng-primitives-extended"],
  "targets": {
    "build": {
      "executor": "@analogjs/platform:vite",
      "options": {
        "configFile": "apps/ng-primitives-docs/vite.config.ts",
        "main": "apps/ng-primitives-docs/src/main.ts",
        "outputPath": "dist/apps/ng-primitives-docs/browser",
        "tsConfig": "apps/ng-primitives-docs/tsconfig.app.json"
      },
      "configurations": {
        "development": {
          "mode": "development"
        },
        "production": {
          "sourcemap": false,
          "mode": "production"
        }
      },
      "outputs": ["{workspaceRoot}/dist/apps/ng-primitives-docs"],
      "defaultConfiguration": "production"
    },
    "serve": {
      "executor": "@analogjs/platform:vite-dev-server",
      "continuous": true,
      "defaultConfiguration": "development",
      "options": {
        "buildTarget": "ng-primitives-docs:build",
        "port": 4200
      },
      "configurations": {
        "development": {
          "buildTarget": "ng-primitives-docs:build:development",
          "hmr": true
        },
        "production": {
          "buildTarget": "ng-primitives-docs:build:production"
        }
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@angular/build:unit-test",
      "options": {}
    }
  }
}
