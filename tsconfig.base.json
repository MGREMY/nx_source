{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@mgremy/ng-primitives": ["packages/ng-primitives/src/index.ts"],
      "@mgremy/ng-primitives/accordion": ["packages/ng-primitives/accordion/src/index.ts"],
      "@mgremy/ng-primitives/breadcrumb": ["packages/ng-primitives/breadcrumb/src/index.ts"],
      "@mgremy/ng-primitives/button": ["packages/ng-primitives/button/src/index.ts"],
      "@mgremy/ng-primitives/checkbox": ["packages/ng-primitives/checkbox/src/index.ts"],
      "@mgremy/ng-primitives/combobox": ["packages/ng-primitives/combobox/src/index.ts"],
      "@mgremy/ng-primitives/dialog": ["packages/ng-primitives/dialog/src/index.ts"],
      "@mgremy/ng-primitives/form-field": ["packages/ng-primitives/form-field/src/index.ts"],
      "@mgremy/ng-primitives/input": ["packages/ng-primitives/input/src/index.ts"],
      "@mgremy/ng-primitives/menu": ["packages/ng-primitives/menu/src/index.ts"],
      "@mgremy/ng-primitives/navbar": ["packages/ng-primitives/navbar/src/index.ts"],
      "@mgremy/ng-primitives/pagination": ["packages/ng-primitives/pagination/src/index.ts"],
      "@mgremy/ng-primitives/switch": ["packages/ng-primitives/switch/src/index.ts"],
      "@mgremy/ng-primitives/toast": ["packages/ng-primitives/toast/src/index.ts"],
      "@mgremy/ng-primitives/tooltip": ["packages/ng-primitives/tooltip/src/index.ts"],
      "@mgremy/ng-primitives-extended": ["packages/ng-primitives-extended/src/index.ts"],
      "@mgremy/ng-primitives-extended/loader": [
        "packages/ng-primitives-extended/loader/src/index.ts"
      ],
      "@mgremy/ng-primitives-extended/navbar": [
        "packages/ng-primitives-extended/navbar/src/index.ts"
      ],
      "@mgremy/ng-primitives-extended/table": [
        "packages/ng-primitives-extended/table/src/index.ts"
      ],
      "@mgremy/core": ["packages/core/src/index.ts"],
      "@mgremy/plugin": ["packages/plugin/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
