FROM node:22-alpine AS build
ENV CI=true
WORKDIR /app
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
RUN npm i -g pnpm && pnpm i --frozen-lockfile
COPY . ./
RUN pnpm exec nx run <%= name %>:build:production

FROM nginx:alpine
RUN apk add --no-cache gettext
COPY --from=build app/dist/apps/<%= name %>/browser/ /usr/share/nginx/html
COPY docker/<%= name %>/nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80

COPY --chmod=755 docker/<%= name %>/entrypoint.sh /entrypoint.sh

ENTRYPOINT ["/entrypoint.sh"]
